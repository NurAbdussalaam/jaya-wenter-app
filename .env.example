# ================================================================
# JAYA WENTER — Environment Variables
# ================================================================
# Salin file ini menjadi .env dan isi nilainya.
# JANGAN commit file .env ke Git.
# ================================================================

# ── RENDER BACKEND API ──────────────────────────────────────────
# URL Render setelah deploy. Contoh:
# RENDER_API_URL=https://jaya-wenter-api.onrender.com
RENDER_API_URL=https://GANTI_DENGAN_URL_RENDER_ANDA

# ── FIREBASE SERVICE ACCOUNT (hanya untuk Render backend) ───────
# Isi dengan isi JSON dari Service Account key (satu baris JSON).
# JANGAN taruh file kunci.json di folder project.
# Taruh nilai JSON ini sebagai env var di dashboard Render.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── ALLOWED ORIGIN (CORS untuk Render backend) ──────────────────
# URL frontend Vercel setelah deploy. Contoh:
# ALLOWED_ORIGIN=https://jaya-wenter-app.vercel.app
ALLOWED_ORIGIN=https://GANTI_DENGAN_URL_VERCEL_ANDA
